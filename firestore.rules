rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: check if user is admin
    function isAdmin() {
      return request.auth != null 
        && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
          request.auth.token.email == 'bugweiser.team@gmail.com' ||
          request.auth.token.email == 'admin@college.edu' ||
          request.auth.token.email == 'admin@dashboard.com'
        );
    }

    // Notices: Anyone can read, only admins can write
    match /notices/{noticeId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();

      // Comments: Any authenticated user can read/create, delete own or admin can delete
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null 
          && (resource.data.authorUid == request.auth.uid || isAdmin());
      }
    }

    // Assignments: Anyone can read, only admins can write
    match /assignments/{assignmentId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    // Users: Users can read/update their own profile, admins can read all
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }
  }
}
